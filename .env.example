# Supabase (legacy — only if VITE_DATA_BACKEND is not mysql)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Data backend: "mysql" = local/Hostinger API (offline-capable). Omit or "supabase" for cloud.
VITE_DATA_BACKEND=mysql
VITE_API_URL=/api

# Skip OTP step in local dev (WhatsApp needs internet)
VITE_DEV_SKIP_OTP=true

# Branding
VITE_COMPANY_NAME=Beyond Company Ltd
VITE_SITE_URL=https://beyondtechworld.com
VITE_CONTACT_EMAIL=info@beyondtechworld.com

# Payment
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key
VITE_MOBILE_MONEY_API_KEY=your_mobile_money_key

# WasenderAPI Integration (New Vision / Manukeza contract)
# Bearer auth + POST {base}/send-message with { to, text }
VITE_WASENDER_API_KEY=your_wasender_api_key
VITE_WASENDER_BASE_URL=https://wasenderapi.com/api
# Default country for local numbers without + prefix (CM=Cameroon, RW=Rwanda)
VITE_DEFAULT_PHONE_COUNTRY=CM
# Legacy — optional, not required for send-message API
VITE_WASENDER_PHONE=+237675321739

# Admin Security
VITE_ADMIN_EMAIL=admin@beyondtechworld.com
VITE_ADMIN_PHONE_NUMBER=+237675321739

# SMTP Configuration
VITE_SMTP_HOST=smtp.example.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=otp@example.com
VITE_SMTP_PASS=your_smtp_password
VITE_SMTP_FROM=otp@example.com
