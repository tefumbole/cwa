# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Payment
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key
VITE_MOBILE_MONEY_API_KEY=your_mobile_money_key

# WasenderAPI Integration
# Note: Ensure there are no spaces around the equals sign and no quotes around values.
VITE_WASENDER_API_KEY=your_wasender_api_key
VITE_WASENDER_API_URL=https://wasenderapi.com/api/send-message
VITE_WASENDER_PHONE=+250XXXXXXXXX

# Admin Security
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PHONE_NUMBER=+250XXXXXXXXX

# SMTP Configuration
VITE_SMTP_HOST=smtp.example.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=otp@example.com
VITE_SMTP_PASS=your_smtp_password
VITE_SMTP_FROM=otp@example.com