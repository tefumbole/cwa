# Copy to apps/api/.env for local offline development
PORT=3003
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
JWT_SECRET=local_dev_jwt_secret_change_in_production

# Homebrew MySQL (default — port 3306). Run: bash tools/setup-local-mysql.sh
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=abt
DB_PASSWORD=alphabridge_local
DB_NAME=alphabridge

# Docker MySQL alternative: DB_PORT=3307 after `docker compose up -d`

SEED_ADMIN_EMAIL=admin@alpha-bridge.net
SEED_ADMIN_PASSWORD=ChangeMe@123456

UPLOAD_DIR=./uploads

# Copy WASENDER_API_KEY from production apps/api/.env for local WhatsApp sends
WASENDER_API_KEY=
WASENDER_BASE_URL=https://wasenderapi.com/api
WASENDER_DEFAULT_COUNTRY=CM
WASENDER_MIN_SEND_INTERVAL_MS=6000
WASENDER_TEXT_TO_DOCUMENT_DELAY_MS=6000
