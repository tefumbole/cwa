# Hostinger MySQL — copy to apps/api/.env on Mac (with Remote MySQL IP whitelisted) or VPS
PORT=3003
NODE_ENV=production
CORS_ORIGIN=https://alpha-bridge.net
APP_URL=https://alpha-bridge.net
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Hostinger hPanel → Databases → MySQL → hostname (often srvXXXX.hstgr.io or IP)
DB_HOST=193.203.168.163
DB_PORT=3306
DB_USER=u152889834_alphabridge
DB_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
DB_NAME=u152889834_alphabridge

SEED_ADMIN_EMAIL=admin@alpha-bridge.net
SEED_ADMIN_PASSWORD=system
SEED_ADMIN_PHONE=+237675321739

# WasenderAPI — server-side OTP (required for WhatsApp login)
WASENDER_API_KEY=your_wasender_api_key
WASENDER_BASE_URL=https://wasenderapi.com/api
WASENDER_DEFAULT_COUNTRY=CM
# Wasender account protection: min gap between send-message calls (ms)
WASENDER_MIN_SEND_INTERVAL_MS=6000
WASENDER_TEXT_TO_DOCUMENT_DELAY_MS=6000

UPLOAD_DIR=./uploads
