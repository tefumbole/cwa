#!/usr/bin/env bash
# Auto-increment CWA patch version on every commit (deploy pipeline).
# Source of truth: laravel-app/VERSION ("CWA V x.y.z"), read by App\Support\AppVersion.
# Skip once with:  SKIP_VERSION_BUMP=1 git commit ...
set -euo pipefail

[ "${SKIP_VERSION_BUMP:-0}" = "1" ] && exit 0

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ ! -f tools/bump-version.js ]]; then
  exit 0
fi

NEXT="$(node tools/bump-version.js | awk -F' -> ' '{print $2}')"
git add laravel-app/VERSION src/constants/appVersion.js apps/api/src/constants/appVersion.js
echo "[pre-commit] version bumped -> ${NEXT}"
